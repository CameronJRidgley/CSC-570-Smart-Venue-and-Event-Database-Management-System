.PHONY: help install dev test lint fmt db-up db-down db-logs migrate revision docker-build docker-up

help:
	@echo "Targets:"
	@echo "  install       Install Python dependencies"
	@echo "  dev           Run uvicorn with --reload"
	@echo "  test          Run pytest"
	@echo "  lint          Run ruff check"
	@echo "  fmt           Run ruff format"
	@echo "  db-up         Start Postgres + Mongo via Docker Compose"
	@echo "  db-down       Stop the DB containers"
	@echo "  db-logs       Tail DB container logs"
	@echo "  migrate       Apply Alembic migrations (upgrade head)"
	@echo "  revision      Create a new autogenerated Alembic revision"
	@echo "  docker-build  Build the API image"
	@echo "  docker-up     Bring up the full stack (api + postgres + mongo)"

install:
	pip install -r requirements.txt

dev:
	uvicorn app.main:app --reload

test:
	pytest

lint:
	ruff check app tests

fmt:
	ruff format app tests

db-up:
	docker compose up -d postgres mongo

db-down:
	docker compose down

db-logs:
	docker compose logs -f postgres mongo

migrate:
	alembic upgrade head

revision:
	alembic revision --autogenerate -m "$(m)"

docker-build:
	docker compose build

docker-up:
	docker compose up -d
